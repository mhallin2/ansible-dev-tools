{
  "containerUser": "root",
  "updateRemoteUserUID": true,
  "image": "ghcr.io/ansible/community-ansible-dev-tools:latest",
  "name": "ansible-dev-container-podman",
  "runArgs": [
    "--cap-add=CAP_MKNOD",
    "--cap-add=NET_ADMIN",
    "--cap-add=SYS_ADMIN",
    "--cap-add=SYS_RESOURCE",
    "--device=/dev/fuse",
    "--security-opt=seccomp=unconfined",
    "--security-opt=label=disable",
    "--security-opt=apparmor=unconfined",
    "--security-opt=unmask=/sys/fs/cgroup",
    "--userns=host",
    "--hostname=ansible-dev-container"
  ],
  "mounts": [
    "source=${localEnv:HOME}/workspace/github,target=/home/runner/github,type=bind,Z"
  ],
  "postCreateCommand": "bash /workspaces/ansible-dev-tools/scripts/configure-git.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "apsislabs.mergetool-navigator",
        "arturock.gitstash",
        "bierner.github-markdown-preview",
        "bierner.markdown-checkbox",
        "bierner.markdown-emoji",
        "bierner.markdown-footnotes",
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "charliermarsh.ruff",
        "chouzz.vscode-better-align",
        "DavidAnson.vscode-markdownlint",
        "dionmunk.vscode-notes",
        "donjayamanne.githistory",
        "dzhavat.bracket-pair-toggler",
        "eamodio.gitlens",
        "erichbehrens.pull-request-monitor",
        "esbenp.prettier-vscode",
        "esbenp.prettier-vscode",
        "foam-vscode.foam-vscode",
        "formulahendry.code-runner",
        "freakypie.code-python-isort",
        "github.vscode-github-actions",
        "GitHub.codespaces",
        "GitHub.copilot",
        "GitHub.remotehub",
        "gruntfuggly.todo-tree",
        "gruntfuggly.triggertaskonsave",
        "IkBenGeenRobot.ansible-variable-lookup",
        "jakob101.relativepath",
        "kortina.vscode-markdown-notes",
        "markis.code-coverage",
        "matangover.mypy",
        "mechatroner.rainbow-csv",
        "mermaidchart.vscode-mermaid-chart",
        "mhutchie.git-graph",
        "migueltarga.ssh-control",
        "mikoz.black-py",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-python.isort",
        "ms-python.mypy-type-checker",
        "ms-python.mypy-type-checker",
        "ms-python.pylint",
        "ms-python.pylint",
        "ms-python.python",
        "oderwat.indent-rainbow",
        "rangav.vscode-thunder-client",
        "redhat.ansible",
        "shd101wyy.markdown-preview-enhanced",
        "shyykoserhiy.git-autoconfig",
        "streetsidesoftware.code-spell-checker",
        "tchayen.markdown-links",
        "tht13.rst-vscode",
        "timonwong.shellcheck",
        "tomblind.scm-buttons-vscode",
        "trond-snekvik.simple-rst",
        "ue.alphabetical-sorter",
        "unjinjang.rest-api-client",
        "valentjn.vscode-ltex",
        "waderyan.gitblame",
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}
